---
import Layout from '../layouts/Layout.astro';

const skillCategories = [
  {
    title: "FRONTEND & UI",
    description: "Creación de interfaces de usuario interactivas, responsivas y veloces.",
    skills: [
      { name: "HTML5 & CSS3", level: 95, color: "from-orange-500 to-yellow-500" },
      { name: "JavaScript (ES6+)", level: 90, color: "from-yellow-400 to-yellow-600" },
      { name: "Vue.js", level: 85, color: "from-emerald-400 to-teal-600" },
      { name: "Astro Framework", level: 85, color: "from-purple-500 to-pink-500" },
      { name: "Tailwind CSS", level: 90, color: "from-cyan-400 to-blue-500" }
    ]
  },
  {
    title: "BACKEND & SYSTEM",
    description: "Construcción de lógica de servidor, comunicación en tiempo real y aplicaciones de escritorio.",
    skills: [
      { name: "Node.js & Express", level: 80, color: "from-green-500 to-emerald-700" },
      { name: "WebSockets", level: 75, color: "from-indigo-400 to-purple-600" },
      { name: "Electron (Desktop)", level: 70, color: "from-blue-400 to-cyan-600" }
    ]
  },
  {
    title: "HERRAMIENTAS & ENTORNO",
    description: "Sistemas de control, empaquetadores y herramientas de desarrollo asistido.",
    skills: [
      { name: "Git & GitHub", level: 85, color: "from-gray-600 to-gray-800" },
      { name: "NPM & Scripts", level: 80, color: "from-red-500 to-red-700" },
      { name: "VS Code", level: 90, color: "from-blue-500 to-indigo-600" },
      { name: "Gemini AI (Pair Programming)", level: 95, color: "from-cyan-300 to-purple-500" }
    ]
  }
];
---

<Layout title="Habilidades | David Guevara">
  <section class="py-10 max-w-4xl mx-auto">
    <!-- Header de Sección -->
    <h2 class="text-3xl font-bold text-white mb-6 flex items-center gap-2 font-mono">
      <span class="text-purple-500">➜</span> CAPACIDADES_DEL_SISTEMA
      <span class="text-gray-600 text-sm font-normal ml-auto hidden md:block">Acceso: Completo</span>
    </h2>

    <p class="text-gray-400 font-mono text-sm mb-12 max-w-2xl border-l-2 border-purple-500/50 pl-4">
      Análisis del stack tecnológico e índices de dominio de herramientas. Actualizado y optimizado continuamente a través de proyectos prácticos e integración de flujos ágiles.
    </p>

    <!-- Listado de Categorías -->
    <div class="space-y-12">
      {skillCategories.map((cat) => (
        <div class="border border-white/10 bg-black/40 rounded-lg p-6 md:p-8 backdrop-blur-sm relative overflow-hidden group">
          <!-- Efecto de luz ambiental en la esquina -->
          <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-cyan-500/10 to-transparent blur-2xl pointer-events-none group-hover:from-purple-500/10 transition-all duration-500"></div>

          <div class="flex flex-col md:flex-row gap-6">
            <!-- Título y descripción de la categoría -->
            <div class="md:w-1/3 flex flex-col justify-start">
              <h3 class="text-xl font-bold text-cyan-400 font-mono tracking-wider mb-2">
                [{cat.title}]
              </h3>
              <p class="text-gray-400 text-sm leading-relaxed">
                {cat.description}
              </p>
            </div>

            <!-- Listado de Habilidades con barra de nivel -->
            <div class="md:w-2/3 space-y-5">
              {cat.skills.map((skill) => (
                <div class="space-y-2">
                  <div class="flex justify-between items-center text-sm font-mono">
                    <span class="text-gray-200">{skill.name}</span>
                    <span class="text-cyan-400 font-bold">{skill.level}%</span>
                  </div>
                  
                  <!-- Barra de progreso de fondo -->
                  <div class="h-2 w-full bg-white/5 rounded-full overflow-hidden border border-white/5">
                    <!-- Barra con gradiente y animación de carga -->
                    <div 
                      class={`h-full bg-gradient-to-r ${skill.color} rounded-full relative shadow-[0_0_8px_rgba(34,211,238,0.3)]`} 
                      style={`width: ${skill.level}%`}
                    >
                      <!-- Efecto brillo deslizante -->
                      <span class="absolute inset-0 bg-[linear-gradient(90deg,transparent,rgba(255,255,255,0.2),transparent)] w-1/2 h-full -skew-x-12 translate-x-[-100%] animate-[pulse-slow_3s_infinite]"></span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Info extra de Optimización -->
    <div class="mt-12 border border-white/5 rounded-lg bg-[#0e0e0e]/50 p-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <div class="w-3.5 h-3.5 bg-green-500 rounded-full animate-ping absolute"></div>
        <div class="w-3.5 h-3.5 bg-green-500 rounded-full relative"></div>
        <span class="text-sm font-mono text-gray-300">SISTEMA TOTALMENTE OPTIMIZADO // ACCELERATED_BY_AI</span>
      </div>
      <div class="flex gap-2">
        <span class="text-xs font-mono text-gray-600">STABILITY: 100%</span>
        <span class="text-xs font-mono text-gray-600">|</span>
        <span class="text-xs font-mono text-gray-600">RESPONSE_TIME: 12ms</span>
      </div>
    </div>
  </section>
</Layout>
