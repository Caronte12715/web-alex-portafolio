---
import Layout from '../layouts/Layout.astro';
---

<Layout title="David Guevara | Web Suite">
	
	<!-- Canvas animado de fondo -->
	<canvas id="bg-canvas" role="presentation" aria-hidden="true" title="Dynamic background animation"></canvas>

	<!-- Redes Sociales Flotantes -->
	<nav class="top-left-socials">
		<a href="https://github.com/Caronte12715" target="_blank" class="social-link" title="GitHub"><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg></a>
		<a href="mailto:david@ejemplo.com" class="social-link" title="Email"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg></a>
	</nav>

	<div class="top-right-share">
		<a href="/contacto" class="share-hub-btn" title="Contactar">Contactar</a>
	</div>

	<header class="hero-header">
		<h1 class="brand-logo">
			<svg class="brand-icon w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
			<strong>David Guevara</strong>
		</h1>
		<h2 class="slogan"><strong>The Ultimate Web Suite</strong></h2>
		<p>Catálogo de Plantillas Profesionales</p>
	</header>

	<main class="sisters-grid">

		<a href="https://caronte12715.github.io/landing-doctor/" target="_blank" class="app-card card-txtly" data-hex="#1cbb3a" data-mode="3">
			<div class="icon-box"><svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg></div>
			<h3><strong>Clínica & Doctor</strong></h3>
			<p class="slogan"><strong>Salud y confianza online!</strong></p>
			<p>Landing page diseñada para médicos y clínicas. Incluye sección de servicios, testimonios y agendamiento de citas.</p>
			<div class="btn-launch">Ver Demo →</div>
		</a>

		<a href="https://caronte12715.github.io/landing-restaurante/" target="_blank" class="app-card card-refacta" data-hex="#ff8c00" data-mode="2">
			<div class="icon-box"><svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2v10z"></path></svg></div>
			<h3><strong>Gourmet Restó</strong></h3>
			<p class="slogan"><strong>Atrae más comensales!</strong></p>
			<p>Plantilla para restaurantes y cafeterías. Exhibe tu menú de forma atractiva, integra reservas y destaca tus platillos estrella.</p>
			<div class="btn-launch">Ver Demo →</div>
		</a>

		<a href="https://caronte12715.github.io/landing-sala-belleza/" target="_blank" class="app-card card-classify" data-hex="#ec4899" data-mode="1">
			<div class="icon-box"><svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"></path></svg></div>
			<h3><strong>Sala de Belleza</strong></h3>
			<p class="slogan"><strong>Estilo y elegancia!</strong></p>
			<p>Ideal para salones de belleza y spas. Muestra tus servicios, galería de trabajos y permite a los clientes reservar fácilmente.</p>
			<div class="btn-launch">Ver Demo →</div>
		</a>
	</main>

	<h2 class="section-label"><strong>Más Plantillas Exclusivas</strong></h2>
	
	<section class="utils-grid">

		<a href="https://caronte12715.github.io/landing-iglesia/" target="_blank" class="app-card card-small card-prismatico" data-hex="#3b82f6" data-mode="4">
			<div class="icon-box"><svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg></div>
			<div class="content">
				<h3><strong>Iglesia Digital</strong></h3>
				<p class="slogan"><strong>Conecta con tu congregación!</strong></p>
				<p>Landing diseñada para iglesias. Promueve eventos, horarios, donaciones y transmite confianza y comunidad.</p>
				<div class="btn-launch">Ver Demo →</div>
			</div>
		</a>

		<a href="https://caronte12715.github.io/landing-servicios-pc/" target="_blank" class="app-card card-small card-hexli" data-hex="#bd00ff" data-mode="5">
			<div class="icon-box"><svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg></div>
			<div class="content">
				<h3><strong>Tech Fix - PC</strong></h3>
				<p class="slogan"><strong>Servicio técnico profesional!</strong></p>
				<p>Destaca tus servicios de reparación, mantenimiento y venta de equipos de cómputo con un diseño tecnológico.</p>
				<div class="btn-launch">Ver Demo →</div>
			</div>
		</a>
	</section>

	<h2 class="section-label"><strong>Software de Descarga (Open Source)</strong></h2>
	
	<section class="utils-grid">

		<a href="https://github.com/Caronte12715/aluro-download-plus" target="_blank" class="app-card card-small card-txtly" data-hex="#1cbb3a" data-mode="3">
			<div class="icon-box"><svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg></div>
			<div class="content">
				<h3><strong>Aluro Download Plus</strong></h3>
				<p class="slogan"><strong>Descargador universal futurista!</strong></p>
				<p>Aplicación de escritorio para descargar videos de múltiples plataformas. Interfaz neo-cyberpunk con alto rendimiento.</p>
				<div class="btn-launch">Ver en GitHub →</div>
			</div>
		</a>

		<a href="https://github.com/Caronte12715/NexGen-Downloader" target="_blank" class="app-card card-small card-refacta" data-hex="#ff8c00" data-mode="2">
			<div class="icon-box"><svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div>
			<div class="content">
				<h3><strong>NexGen Downloader</strong></h3>
				<p class="slogan"><strong>Plataforma todo-en-uno!</strong></p>
				<p>Extrae y descarga contenido multimedia desde cualquier red social con este potente motor de descarga de última generación.</p>
				<div class="btn-launch">Ver en GitHub →</div>
			</div>
		</a>
	</section>

</Layout>

<style is:global>
	@import url("https://fonts.googleapis.com/css2?family=Mulish:wght@300;400;700;800;900&display=swap");

	:root {
		--none: 0;
		--xxxs: 0.01em;
		--xxs: 0.25em;
		--xs: 0.5em;
		--sm: 0.75em;
		--md: 1em;
		--lg: 1.25em;
		--xl: 1.5em;
		--xxl: 1.75em;
		--xxxl: 2em;

		--black: 0, 0, 0;
		--dark: 10, 10, 10;
		--darker-grey: 30, 30, 30;

		--white: 255, 255, 255;
		--gray: 136, 136, 136;
		--pink: 236, 72, 153;
		--orange: 255, 140, 0;
		--green: 28, 187, 58;
		--blue: 59, 130, 246;
		--purple: 189, 0, 255;

		--alpha: 0.25;
		--alpha-border: 0.08;
		--font-main: "Mulish", sans-serif;
	}

	body {
		background-color: transparent !important; 
	}

	#bg-canvas {
		position: fixed;
		inset: var(--none);
		z-index: -10;
		opacity: var(--none);
		pointer-events: none;
		width: 100vw;
		height: 100vh;
	}
	
	.top-left-socials {
		position: fixed;
		top: var(--xxl);
		left: var(--xxl);
		z-index: 100;
		display: flex;
		gap: var(--sm);

		@media (max-width: 600px) {
			top: var(--md);
			left: var(--md);
			gap: var(--xs);
		}

		.social-link {
			width: calc(var(--xxxl) + var(--xs));
			height: calc(var(--xxxl) + var(--xs));
			border-radius: var(--xxxl);
			background: rgba(var(--gray), var(--alpha));
			display: flex;
			align-items: center;
			justify-content: center;
			color: rgba(var(--white), var(--alpha));
			text-decoration: none;
			font-size: var(--lg);
			border: calc(var(--xxxs) * 6) solid rgba(var(--white), var(--alpha-border));
			backdrop-filter: blur(5px);
			transition: all 0.5s;

			&:hover {
				background: rgb(var(--white));
				color: rgb(var(--black));
				transform: scale(1.1);
				box-shadow: 0 0 var(--md) rgba(255, 255, 255, 0.5);
			}
		}
	}

	.top-right-share {
		position: fixed;
		top: var(--xxl);
		right: var(--xxl);
		z-index: 100;

		@media (max-width: 600px) {
			top: var(--md);
			right: var(--md);
		}

		.share-hub-btn {
			background: linear-gradient(90deg, rgb(var(--orange)), rgb(var(--pink)));
			border: var(--none);
			padding: var(--sm) var(--xl);
			border-radius: var(--xxxl);
			color: rgb(var(--white));
			font-weight: 800;
			cursor: pointer;
			text-decoration: none;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			font-size: var(--sm);
			box-shadow: 0 var(--xs) var(--lg) rgba(0, 0, 0, var(--alpha));
			backdrop-filter: blur(5px);
			transition: all 0.5s;

			&:hover {
				transform: translateY(calc(var(--xxs) * -0.5));
				box-shadow: 0 var(--sm) var(--xl) rgba(var(--orange), 0.4);
			}
		}
	}

	.hero-header {
		text-align: center;
		padding: calc(var(--xxxl) * 2) var(--md) var(--xxl) var(--md);
		z-index: 10;
		font-family: var(--font-main);

		.brand-logo {
			font-size: calc(var(--xxxl) + var(--xl));
			margin-bottom: var(--xs);
			display: flex;
			align-items: center;
			justify-content: center;
			gap: var(--xxs);
			background: linear-gradient(to right, rgb(var(--white)), rgb(var(--white)));
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			text-shadow: 0 var(--md) var(--xl) rgba(0, 0, 0, 0.5);

			@media (max-width: 600px) {
				font-size: calc(var(--xxxl) + var(--xs));
				gap: var(--sm);
			}

			strong {
				font-weight: 900;
				letter-spacing: -0.05em;
			}

			.brand-icon {
				color: rgb(var(--white));
				filter: drop-shadow(0 0 var(--md) rgba(var(--white), 0.3));
			}
		}

		.slogan {
			font-size: var(--xl);
			color: rgb(var(--white));
			letter-spacing: 0.05em;

			@media (max-width: 600px) {
				font-size: var(--lg);
			}

			strong {
				font-weight: 700;
				color: rgb(var(--white));
			}
		}

		p {
			margin-top: var(--sm);
			color: rgb(var(--gray));
			font-size: var(--md);
		}
	}

	main.sisters-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--xxl);
		max-width: 100%;
		width: 100%;
		margin: 0 auto var(--xxxl);
		perspective: 1000px;
		z-index: 10;
		font-family: var(--font-main);

		@media (max-width: 1024px) {
			grid-template-columns: repeat(2, 1fr);
		}

		@media (max-width: 768px) {
			grid-template-columns: 1fr;
			gap: var(--lg);
		}
	}

	.section-label {
		text-align: center;
		color: rgb(var(--white));
		font-size: var(--xl);
		letter-spacing: 0.1em;
		margin: var(--xxl) 0;
		position: relative;
		z-index: 2;
		font-family: var(--font-main);

		strong {
			font-weight: 800;
			color: rgb(var(--white));
		}
	}

	.utils-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--xxl);
		max-width: 100%;
		width: 100%;
		margin: 0 auto var(--xxxl);
		z-index: 10;
		font-family: var(--font-main);

		@media (max-width: 900px) {
			grid-template-columns: 1fr;
			gap: var(--lg);
		}
	}

	.app-card {
		--theme-color: 255, 255, 255;
		background: rgba(var(--dark), var(--alpha));
		border: calc(var(--xxxs) * 6) solid rgba(var(--white), var(--alpha-border));
		border-radius: var(--lg);
		padding: var(--xxl);
		text-decoration: none;
		color: rgb(var(--white));
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		position: relative;
		overflow: hidden;
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
		transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
		box-shadow: 0 var(--xs) var(--lg) rgba(0, 0, 0, var(--alpha));
		cursor: pointer;

		&.card-txtly { --theme-color: var(--green); }
		&.card-refacta { --theme-color: var(--orange); }
		&.card-classify { --theme-color: var(--pink); }
		&.card-prismatico { --theme-color: var(--blue); }
		&.card-hexli { --theme-color: var(--purple); }

		&:hover {
			transform: translateY(calc(var(--xs) * -1)) scale(1.02);
			box-shadow: 0 var(--xl) calc(var(--xxxl) * 2) rgba(0, 0, 0, var(--alpha));
			border-color: rgba(var(--white), 0.2);
			background: rgba(var(--darker-grey), 0.6);

			.icon-box {
				background: rgb(var(--theme-color));
				color: rgb(var(--black));
				box-shadow: 0 0 calc(var(--xxxl) + var(--xs)) rgb(var(--theme-color));
				border-color: transparent;
			}

			h3 strong,
			h2 strong {
				color: rgb(var(--theme-color));
			}

			.btn-launch {
				border-color: rgb(var(--theme-color));
				color: rgb(var(--theme-color));
			}
		}

		&.card-prismatico:hover .icon-box,
		&.card-hexli:hover .icon-box {
			color: rgb(var(--white));
		}

		.icon-box {
			width: calc(var(--xxxl) * 1.5);
			height: calc(var(--xxxl) * 1.5);
			border-radius: var(--md);
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: var(--xxxl);
			background: rgba(var(--gray), var(--alpha));
			border: calc(var(--xxxs) * 6) solid rgba(var(--white), var(--alpha-border));
			margin-bottom: var(--xl);
			position: relative;
			z-index: 2;
			flex-shrink: 0;
			transition: all 0.5s;
		}

		h3 {
			font-size: var(--xxl);
			margin: var(--none) var(--none) var(--xs) var(--none);
			position: relative;
			z-index: 2;
			line-height: 1.1;

			strong {
				font-weight: 900;
				transition: color 0.5s;
			}
		}

		.slogan {
			font-size: var(--md);
			margin-bottom: var(--md);
			color: rgb(var(--white));
			letter-spacing: var(--none);
			line-height: 1.4;
			position: relative;
			z-index: 2;

			strong {
				font-weight: 700;
				color: rgb(var(--white));
			}
		}

		p {
			font-size: var(--md);
			color: rgb(var(--gray));
			line-height: 1.6;
			margin-bottom: var(--xxxl);
			position: relative;
			z-index: 2;

			&:last-of-type {
				flex-grow: 1;
			}
		}

		.btn-launch {
			margin-top: auto;
			padding: calc(var(--xs) + var(--xxxs) * 10) calc(var(--md) + var(--xxs));
			border-radius: var(--xxxl);
			font-weight: 700;
			font-size: var(--sm);
			border: calc(var(--xxxs) * 6) solid rgba(var(--white), var(--alpha-border));
			background: rgba(0, 0, 0, 0.3);
			color: rgb(var(--white));
			display: flex;
			align-items: center;
			gap: var(--xs);
			position: relative;
			z-index: 2;
			width: fit-content;
			transition: all 0.5s;
		}
	}

	.card-small {
		padding: var(--xxxl);
		flex-direction: row;
		align-items: flex-start;
		gap: var(--xl);

		@media (max-width: 600px) {
			padding: var(--xl);
			flex-direction: column;
		}

		.icon-box {
			margin-bottom: var(--none);
			width: calc(var(--xxxl) + var(--md));
			height: calc(var(--xxxl) + var(--md));
			font-size: var(--xl);
			margin-top: var(--xxs);

			@media (max-width: 600px) {
				margin-bottom: var(--md);
			}
		}

		.content {
			display: flex;
			flex-direction: column;
			position: relative;
			z-index: 2;
			flex: 1;
		}

		h3 {
			font-size: var(--xl);
			margin-bottom: var(--xxs);
		}

		.slogan {
			margin-bottom: var(--sm);
			font-size: var(--sm);
			opacity: var(--alpha);
		}

		p {
			font-size: var(--md);
			margin-bottom: var(--lg);
			line-height: 1.5;
		}

		.btn-launch {
			margin-top: auto;
			font-size: var(--sm);
			padding: var(--xs) var(--md);
			align-self: flex-start;
		}
	}
</style>

<script>
	import * as THREE from 'three';

	document.addEventListener('DOMContentLoaded', () => {
		const canvas = document.getElementById("bg-canvas") as HTMLCanvasElement;
		if (!canvas) return;

		const scene = new THREE.Scene();
		const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);
		const renderer = new THREE.WebGLRenderer({
			canvas: canvas,
			alpha: true
		});

		const uniforms = {
			uTime: { value: 0 },
			uColor: { value: new THREE.Color(0x090909) },
			uResolution: { value: new THREE.Vector2() },
			uMouse: { value: new THREE.Vector2(0.5, 0.5) },
			uIntensity: { value: 0.0 },
			uMode: { value: 0 }
		};

		const material = new THREE.ShaderMaterial({
			uniforms: uniforms,
			vertexShader: `
				varying vec2 vUv;
				void main() {
					vUv = uv;
					gl_Position = vec4(position, 1.0);
				}
			`,
			fragmentShader: `
				uniform float uTime;
				uniform vec3 uColor;
				uniform vec2 uResolution;
				uniform vec2 uMouse;
				uniform float uIntensity; 
				uniform int uMode; 
				varying vec2 vUv;

				float random(vec2 st) { return fract(sin(dot(st.xy, vec2(12.9898,78.233))) * 43758.5453123); }
				
				float noise(vec2 st) {
					vec2 i = floor(st); vec2 f = fract(st);
					float a = random(i); float b = random(i + vec2(1.0, 0.0));
					float c = random(i + vec2(0.0, 1.0)); float d = random(i + vec2(1.0, 1.0));
					vec2 u = f * f * (3.0 - 2.0 * f);
					return mix(a, b, u.x) + (c - a)* u.y * (1.0 - u.x) + (d - b) * u.x * u.y;
				}
				
				float fbm(vec2 st) {
					float value = 0.0; float amp = .5;
					for (int i = 0; i < 5; i++) { value += amp * noise(st); st *= 2.; amp *= .5; }
					return value;
				}

				float grid(vec2 st, float res) {
					vec2 grid = fract(st * res);
					return (step(0.98, grid.x*1.03) + step(0.98, grid.y*1.03));
				}

				void main() {
					vec2 st = gl_FragCoord.xy / uResolution.xy;
					float aspect = uResolution.x / uResolution.y;
					st.x *= aspect;

					vec2 mousePos = uMouse;
					mousePos.x *= aspect; 
					vec2 toMouse = st - mousePos;
					float distMouse = length(toMouse);
					float mouseInteraction = smoothstep(0.4, 0.0, distMouse);

					vec3 finalColor = vec3(0.0);
					vec2 warpSt = st; 
					
					if (uMode == 0) {
						warpSt -= toMouse * mouseInteraction * 0.05;
						warpSt.x += sin(st.y * 5.0 + uTime * 0.2) * 0.01;
					}
					else if (uMode == 1) { 
						float speed = 0.1;
						vec2 flowDistort = toMouse * mouseInteraction * 1.5;
						vec2 q = vec2(fbm(st + flowDistort + vec2(0.0, uTime * speed)), fbm(st + vec2(5.2, 1.3)));
						vec2 r = vec2(fbm(st + 4.0 * q + vec2(uTime * speed)), fbm(st + 4.0 * q + vec2(5.2)));
						float f = fbm(st + 4.0 * r);
						warpSt += r * 0.1 * uIntensity;
						vec3 psychedelic = mix(uColor, uColor * 1.8, f); 
						finalColor += psychedelic * f * f * uIntensity;
					} 
					else if (uMode == 2) {
						float speed = 1.5;
						warpSt += toMouse * mouseInteraction * 0.2;
						float fire = fbm(st * 4.0 + vec2(0.0, -uTime * speed)); 
						warpSt.x += fire * 0.05 * uIntensity; 
						warpSt.y += fire * 0.08 * uIntensity;
						float heat = smoothstep(0.0, 1.0, fire);
						vec3 cRed = vec3(0.8, 0.1, 0.0);
						vec3 cOrange = vec3(1.0, 0.5, 0.0);
						vec3 cYellow = vec3(1.0, 0.9, 0.2);
						vec3 fireCol = mix(cRed, cOrange, heat);
						fireCol = mix(fireCol, cYellow, smoothstep(0.5, 1.0, heat));
						finalColor += fireCol * heat * (1.4 - vUv.y) * 0.8 * uIntensity; 
					}
					else if (uMode == 3) {
						float t = uTime * 0.3;
						vec2 q = st * vec2(1.0, 0.5); 
						float aurora = 0.0;
						for(float i = 1.0; i < 4.0; i++) {
							float wavy = sin(q.x * 2.0 * i + t * i) * 0.3;
							wavy += mouseInteraction * 0.2 * sin(uTime * 5.0);
							float y = q.y - 0.3 - wavy * 0.2;
							float band = smoothstep(0.0, 0.1, y) * smoothstep(0.6, 0.1, y);
							float n = fbm(q * 10.0 * i + vec2(0.0, t * 2.0));
							aurora += band * n * (1.0 / i);
						}
						warpSt += vec2(0.0, aurora) * 0.2 * uIntensity;
						vec3 colA = vec3(0.0, 1.0, 0.1); 
						vec3 colB = vec3(0.0, 0.9, 0.6); 
						vec3 finalAurora = mix(colA, colB, st.x + sin(t));
						finalColor += finalAurora * aurora * 0.6 * uIntensity;
						finalColor += uColor * mouseInteraction * 0.3;
					}
					else if (uMode == 4) {
						float speed = 0.1;
						warpSt -= toMouse * mouseInteraction * 0.3;
						vec2 q = vec2(fbm(st + speed*uTime), fbm(st + vec2(1.0)));
						float f = fbm(st + q + uTime*speed);
						warpSt += f * 0.5 * uIntensity;
						finalColor += uColor * f * 0.6 * uIntensity;
					}
					else if (uMode == 5) {
						vec2 vortexCenter = vec2(aspect, 0.0);
						vec2 toCenter = st - vortexCenter;
						float len = length(toCenter);
						float angle = atan(toCenter.y, toCenter.x);
						float twist = len * 10.0 - uTime * 2.0;
						twist += mouseInteraction * 5.0; 
						float f = sin(angle * 5.0 + twist);
						warpSt += vec2(cos(f), sin(f)) * 0.05 * uIntensity;
						finalColor += uColor * smoothstep(0.0, 1.0, f) * (1.0 - len) * 0.5 * uIntensity;
					}

					float g = grid(warpSt, 20.0); 
					vec3 gridBase = vec3(0.15); 
					vec3 gridActive = uColor * 0.8;
					vec3 finalGridCol = mix(gridBase, gridActive, uIntensity * 0.8);
					finalColor += vec3(g) * finalGridCol;

					float dist = distance(vUv, vec2(0.5));
					finalColor *= 1.0 - dist * 0.6;

					gl_FragColor = vec4(finalColor, 1.0);
				}
			`
		});

		const plane = new THREE.Mesh(new THREE.PlaneGeometry(2, 2), material);
		scene.add(plane);

		function resize() {
			const width = window.innerWidth;
			const height = window.innerHeight;
			renderer.setSize(width, height);
			uniforms.uResolution.value.set(width, height);
		}
		window.addEventListener("resize", resize);
		resize();

		window.addEventListener("mousemove", (e) => {
			const x = e.clientX / window.innerWidth;
			const y = 1.0 - e.clientY / window.innerHeight;
			uniforms.uMouse.value.set(x, y);
		});

		let targetColor = new THREE.Color(0x050505);
		const defaultColor = new THREE.Color(0x050505);
		let targetIntensity = 0.0;

		function animate(time: number) {
			requestAnimationFrame(animate);
			uniforms.uTime.value = time * 0.001;
			uniforms.uColor.value.lerp(targetColor, 0.04);
			uniforms.uIntensity.value +=
				(targetIntensity - uniforms.uIntensity.value) * 0.05;
			renderer.render(scene, camera);
		}
		requestAnimationFrame(animate);

		setTimeout(() => {
			canvas.style.opacity = '1';
		}, 100);

		const cards = document.querySelectorAll(".app-card");
		cards.forEach((card) => {
			card.addEventListener("mouseenter", () => {
				const hex = card.getAttribute("data-hex");
				const mode = parseInt(card.getAttribute("data-mode") || '0');
				if (hex) targetColor.set(hex);
				uniforms.uMode.value = mode;
				targetIntensity = 1.0;
			});
			card.addEventListener("mouseleave", () => {
				targetColor.copy(defaultColor);
				targetIntensity = 0.0;
			});
		});
	});
</script>