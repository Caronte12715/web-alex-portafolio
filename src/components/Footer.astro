---
const currentYear = new Date().getFullYear();
---

<footer class="mt-20 border-t border-white/10 bg-black/20 backdrop-blur-sm">
    <div class="max-w-5xl mx-auto px-4 py-12">
        <div class="flex flex-col md:flex-row justify-between items-center gap-6">
            
            <div class="text-left">
                <div class="flex items-center gap-2 mb-2">
                    <div class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></div>
                    <span class="text-red-400 font-mono text-xs tracking-widest">SYSTEM_STANDBY</span>
                </div>
                <p class="text-gray-500 text-sm font-mono">
                    © {currentYear} Acceso concedido. <br />
                    Desarrollado con <span class="text-cyan-400">Astro</span> & <span class="text-purple-400">Tailwind</span>.
                </p>
            </div>

            <div class="flex gap-6">
                <a href="https://github.com" target="_blank" class="text-gray-400 hover:text-white transition-colors font-mono text-sm hover:underline decoration-cyan-400 decoration-2 underline-offset-4">
                    [GITHUB]
                </a>
                <a href="https://linkedin.com" target="_blank" class="text-gray-400 hover:text-white transition-colors font-mono text-sm hover:underline decoration-purple-500 decoration-2 underline-offset-4">
                    [LINKEDIN]
                </a>
            </div>

        </div>
        
        <div class="mt-8 text-center">
            <p class="text-[10px] text-gray-700 font-mono">
                ID DE SESIÓN: {Math.random().toString(36).substring(7).toUpperCase()} // CONEXIÓN SEGURA
            </p>
        </div>
    </div>
</footer>