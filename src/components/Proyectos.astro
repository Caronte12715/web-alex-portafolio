---
const projects = [
  {
    title: "ORBIT (GRAPHICSLIVE)",
    description: "Motor de gráficos profesionales para transmisiones en vivo y streaming. Desarrollado como aplicación de escritorio con Electron, sincronización en tiempo real vía WebSockets y control remoto móvil.",
    tech: ["Electron", "Express", "WebSockets", "Node.js"],
    status: "v1.1.0",
    link: "https://github.com/Caronte12715/graphicslive"
  },
  {
    title: "COLEGIO CRISMAG",
    description: "Sitio institucional educativo. Migrado de HTML/JS estático a Astro para mejorar el rendimiento y la mantenibilidad.",
    tech: ["Astro", "JavaScript", "CSS"], // <--- Actualizado
    status: "Online",
    link: "https://www.colegiocrismag.com"
  },
  {
    title: "MAL ESPÍRITU",
    description: "Espacio de experimentación creativa y desarrollo web personal.",
    tech: ["Astro", "HTML", "CSS"], // <--- Actualizado
    status: "En desarrollo",
    link: "https://mal-espiritu.pages.dev"
  },
  {
    title: "MI PORTAFOLIO",
    description: "Identidad digital desarrollada con arquitectura moderna, estilos neón y asistencia de IA.",
    tech: ["Astro", "Tailwind", "Gemini AI"],
    status: "v1.0",
    link: "#"
  }
];
---

<section id="proyectos" class="py-20">
  <h2 class="text-3xl font-bold text-white mb-10 flex items-center gap-2">
    <span class="text-cyan-400">./</span> PROYECTOS_DESTACADOS
    <span class="text-gray-600 text-sm font-normal ml-auto hidden md:block">Index of /projects</span>
  </h2>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {projects.map((project) => (
      <a href={project.link} target="_blank" class="group relative block bg-black/50 border border-white/10 hover:border-cyan-400/50 rounded-lg p-6 transition-all hover:shadow-[0_0_15px_rgba(34,211,238,0.1)] hover:-translate-y-1">
        
        <div class="absolute top-0 right-0 p-2 opacity-50">
            <div class="w-2 h-2 bg-gray-500 rounded-full group-hover:bg-cyan-400 transition-colors"></div>
        </div>

        <div class="flex flex-col h-full justify-between">
            <div>
                <span class="text-xs font-mono text-cyan-400 mb-2 block">{project.status}</span>
                <h3 class="text-xl font-bold text-white mb-2 group-hover:text-cyan-300 transition-colors">
                    {project.title}
                </h3>
                <p class="text-gray-400 text-sm mb-4 leading-relaxed">
                    {project.description}
                </p>
            </div>
            
            <div class="flex flex-wrap gap-2 mt-4 pt-4 border-t border-white/5">
                {project.tech.map((t) => (
                    <span class="text-xs font-mono text-gray-500 bg-white/5 px-2 py-1 rounded group-hover:text-gray-300 transition-colors">
                        {t}
                    </span>
                ))}
            </div>
        </div>
      </a>
    ))}
  </div>
</section>