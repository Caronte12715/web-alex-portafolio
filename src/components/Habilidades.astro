---
const skills = [
  {
    category: "FRONTEND & UI",
    items: ["HTML5", "CSS3", "JavaScript (ES6+)", "Vue.js", "Astro Framework", "Tailwind CSS"]
  },
  {
    category: "BACKEND & SYSTEM",
    items: ["Node.js", "Express", "WebSockets", "Electron (Apps Escritorio)"]
  },
  {
    category: "HERRAMIENTAS & ENTORNO",
    items: ["Git / GitHub", "NPM", "VS Code", "Gemini AI (Pair Programming)"]
  }
];
---

<section id="habilidades" class="py-20 relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"></div>

    <div class="relative z-10">
        <h2 class="text-3xl font-bold text-white mb-12 flex items-center gap-2">
            <span class="text-purple-500">➜</span> CAPACIDADES_DEL_SISTEMA
        </h2>

        <div class="grid gap-6 md:grid-cols-3">
            {skills.map((group) => (
                <div class="border border-white/10 bg-black/40 p-6 rounded-lg backdrop-blur-sm hover:border-purple-500/50 transition-colors duration-300">
                    <h3 class="text-cyan-400 font-mono text-sm mb-4 tracking-wider border-b border-white/5 pb-2">
                        [{group.category}]
                    </h3>
                    
                    <div class="flex flex-wrap gap-3">
                        {group.items.map((item) => (
                            <div class="group relative px-4 py-2 bg-white/5 border border-white/10 rounded hover:bg-white/10 transition-all cursor-default hover:scale-105 hover:border-cyan-400/30">
                                <span class="text-gray-300 font-mono text-sm group-hover:text-cyan-400 transition-colors">
                                    {item}
                                </span>
                                <span class="absolute -bottom-px left-0 w-0 h-px bg-gradient-to-r from-cyan-400/0 via-cyan-400/70 to-cyan-400/0 group-hover:w-full transition-all duration-500"></span>
                            </div>
                        ))}
                    </div>
                </div>
            ))}
        </div>
        
        <div class="mt-12 flex items-center gap-4 text-xs font-mono text-gray-600">
            <span>APRENDIZAJE EN PROGRESO:</span>
            <div class="h-1 w-32 bg-gray-800 rounded-full overflow-hidden">
                <div class="h-full bg-purple-500 w-[75%] animate-pulse"></div>
            </div>
            <span>OPTIMIZADO</span>
        </div>
    </div>
</section>